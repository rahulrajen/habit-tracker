{
  "name": "habit-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/habit_tracker\" tsx src/scripts/seed.ts",
    "test": "node scripts/reset-test-db.mjs && vitest run",
    "test:watch": "vitest",
    "playwright": "playwright test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@tanstack/react-query": "^5.24.0",
    "canvas-confetti": "^1.9.3",
    "drizzle-orm": "^0.32.0",
    "framer-motion": "^11.0.0",
    "next": "^14.2.0",
    "pg": "^8.12.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@dnd-kit/utilities": "^3.2.2",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.4.0",
