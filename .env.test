# ============================================================================
# .env.test — loaded automatically by dotenv when NODE_ENV=test (vitest).
# This file exists so @core/db.ts can read TEST_DATABASE_URL before any test
# file imports @core/db or its actions.  Vitest auto-loads .env files via
> the dotenv module, and .env.test is one of the standard filenames it checks.
# ============================================================================

# Local Postgres (Docker) — test database
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/habit_tracker_test
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/habit_tracker_test
